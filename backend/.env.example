# Project Settings
PROJECT_NAME="Student ERP Backend"
API_V1_STR="/api/v1"
DEBUG=True

# Database Configuration (Supabase)
# Find this in your Supabase Dashboard -> Project Settings -> Database -> Connection string (URI)
# Note: Ensure you are using the connection string and not just the REST API URL.
DATABASE_URL=postgresql://postgres.[project-ref]:[your-password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Security
# Generate a secure secret key using: openssl rand -hex 32
SECRET_KEY=your-super-secret-key-replace-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Initial Super User
FIRST_SUPERUSER_EMAIL=admin@example.com
FIRST_SUPERUSER_PASSWORD=admin
